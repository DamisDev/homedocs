# Reverse proxy di produzione con TLS automatico (Let's Encrypt).
# Sostituisci "tuodominio.it" con il dominio reale in entrambi i blocchi
# prima del deploy, e crea un record DNS A anche per il sottodominio "api".
#
# Le route del backend non hanno un prefisso /api (vedi apps/backend/src/main.ts,
# nessun setGlobalPrefix) — per questo si usa un sottodominio dedicato invece
# di un path-based routing, evitando qualsiasi riscrittura di path.

homedocs.dev {
	reverse_proxy frontend:80
}

api.homedocs.dev {
	reverse_proxy backend:3000
}

# Espone solo l'API S3 di MinIO (porta 9000), per gli URL firmati che il
# browser apre per scaricare/visualizzare i file. La console (9001) resta
# interna. Caddy preserva l'Host, necessario per la validazione della firma
# SigV4 lato MinIO.
storage.homedocs.dev {
	reverse_proxy minio:9000
}
