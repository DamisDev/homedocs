# Dockerfile.dev — Servizio OCR/AI (Python + FastAPI)
# NOTA: questo è uno scaffolding minimo. Claude Code completerà il progetto
# reale (requirements.txt, endpoint FastAPI) nella Fase 2.

FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir --break-system-packages -r requirements.txt

COPY . .

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
