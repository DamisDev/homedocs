# Dockerfile.dev — Backend core (NestJS)
# NOTA: questo è uno scaffolding minimo. Claude Code completerà il progetto
# reale (package.json, moduli NestJS) nella Fase 0/1.

FROM node:22-alpine

WORKDIR /app

COPY package*.json ./
RUN if [ -f package.json ]; then npm install; fi

COPY . .

EXPOSE 3000

CMD ["npm", "run", "start:dev"]
