# Copia questo file in .env e riempi i valori reali.
# NON committare mai il file .env con valori veri.

# Servizio OCR/AI — chiave API Claude
ANTHROPIC_API_KEY=

# JWT (backend) — genera segreti robusti in produzione
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too
# TTL opzionali dei token (default: 15m access, 7d refresh)
#JWT_ACCESS_TTL=15m
#JWT_REFRESH_TTL=7d

# CORS — origin consentite dal backend, separate da virgola (fallback:
# FRONTEND_URL singolo, poi http://localhost:5173)
# In produzione: CORS_ORIGINS=https://tuodominio.it
CORS_ORIGINS=http://localhost:5173

# Frontend — URL pubblico del backend, inlineato nel bundle in fase di build
# (build arg del Dockerfile, non leggibile a runtime). In produzione, dominio
# del sottodominio API dietro Caddy: VITE_API_URL=https://api.tuodominio.it
VITE_API_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://mongo:27017/homedocs

# MinIO (storage file S3-compatible)
MINIO_ENDPOINT=minio
# Host con cui il browser raggiunge MinIO (per gli URL firmati)
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=homedocs
MINIO_SECRET_KEY=homedocs123
MINIO_BUCKET=homedocs-documents

# Email promemoria scadenze
# Dev: Mailpit del docker-compose (valori sotto). In produzione, sostituire
# con le credenziali SMTP di Amazon SES o, come alternativa senza attesa di
# approvazione, Brevo (smtp-relay.brevo.com:587, SMTP_SECURE=false).
SMTP_HOST=mailpit
SMTP_PORT=1025
#SMTP_SECURE=false
#SMTP_USER=
#SMTP_PASS=
MAIL_FROM=HomeDocs <noreply@homedocs.local>
